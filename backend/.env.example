# =============================================================================
# Confluence2.0 / Atlas backend — AI provider configuration
# =============================================================================
# IMPORTANT: This app does NOT use Cursor IDE API keys.
# You need your own OpenAI and/or Google Gemini API key below.
#
# File location (Windows example):
#   C:\My Workspace\SrcCode\Training\AIProjects\backend\.env
#
# Get keys:
#   OpenAI: https://platform.openai.com/api-keys
#   Google: https://aistudio.google.com/apikey
# =============================================================================

# Which provider to use: openai | google | auto
# Recommended while OpenAI quota is exhausted: google
LLM_PROVIDER=google

# --- OpenAI (optional if using Google only) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_SSL_VERIFY=true

# --- Google Gemini (recommended for demo) ---
# GOOGLE_API_KEY and GEMINI_API_KEY are both accepted
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
GOOGLE_CHAT_MODEL=gemini-2.0-flash

# --- App settings ---
DATABASE_URL=sqlite:///./atlas.db
KNOWLEDGE_BASE_ROOT=knowledge_base
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# After saving this file:
#   1. Restart backend: python -m uvicorn app.main:app --reload --port 8000
#   2. Test keys:       http://localhost:8000/api/health/test-llm
#   3. Re-save a page or Ask a question to re-index content
# =============================================================================
