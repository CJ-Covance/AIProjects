# Provider: openai | google | auto
# auto = try OpenAI first, fall back to Google on quota/rate-limit (429) errors
# If OpenAI quota is exhausted, set LLM_PROVIDER=google
LLM_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_SSL_VERIFY=true

GOOGLE_API_KEY=
# text-embedding-004 was retired; use gemini-embedding-001 for Gemini API keys
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
GOOGLE_CHAT_MODEL=gemini-2.0-flash

DATABASE_URL=sqlite:///./atlas.db
KNOWLEDGE_BASE_ROOT=knowledge_base
CORS_ORIGINS=http://localhost:3000
