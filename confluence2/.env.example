# ── Database (local Postgres; on Replit use the integration-provided URL) ──
DATABASE_URL=postgresql://confluence2:confluence2@localhost:5432/confluence2

# ── Replit Auth (populated automatically on Replit) ──
REPL_ID=
ISSUER_URL=https://replit.com/oidc
SESSION_SECRET=change-me-to-a-long-random-string
REPLIT_DOMAINS=localhost:5000,localhost:5173

# ── Replit AI / Gemini proxy (populated automatically on Replit) ──
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# ── Local dev fallbacks (when not running on Replit) ──
DEV_AUTH_BYPASS=true
GOOGLE_API_KEY=

# ── Server ──
PORT=5000
WEB_ORIGIN=http://localhost:5173
